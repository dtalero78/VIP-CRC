---
import { site } from '../data/site';
---

<section class="py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-700 via-brand-800 to-brand-950 p-10 lg:p-14">
      <div class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-accent-500/20 blur-3xl"></div>
      <div class="absolute -bottom-32 -left-16 h-80 w-80 rounded-full bg-brand-400/20 blur-3xl"></div>

      <div class="relative grid lg:grid-cols-3 gap-8 items-center">
        <div class="lg:col-span-2">
          <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-white">
            Tu licencia, sin demoras.
          </h2>
          <p class="mt-3 text-lg text-brand-100 max-w-2xl">
            Reserva hoy y obtén tu certificado médico para licencia de conducción en una sola visita.
            Atención personalizada y reporte inmediato al RUNT.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 lg:justify-end">
          <a
            href={site.social.whatsapp}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-full bg-accent-500 hover:bg-accent-600 px-6 py-3 text-base font-semibold text-white shadow-lg"
          >
            Agendar por WhatsApp
          </a>
          <a
            href={`tel:+57${site.phone.landline}`}
            class="inline-flex items-center gap-2 rounded-full bg-white hover:bg-brand-50 px-6 py-3 text-base font-semibold text-brand-800"
          >
            Llamar
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
