---
import { site } from '../data/site';
const mapsUrl = `https://www.google.com/maps?q=${site.address.mapsQuery}&output=embed`;
---

<section id="contacto" class="py-20 lg:py-28 bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12">
      <div id="agendar">
        <span class="inline-flex items-center text-xs font-bold uppercase tracking-wider text-brand-700">Agendar cita</span>
        <h2 class="mt-2 text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          ¿Listo para tu examen?
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          Estamos a un mensaje de distancia. Reserva tu cita y te confirmamos en minutos.
        </p>

        <ul class="mt-8 space-y-4">
          <li class="flex items-start gap-4">
            <div class="h-11 w-11 rounded-xl bg-white grid place-items-center ring-1 ring-slate-200 text-brand-700">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Sede Bogotá</p>
              <p class="text-sm font-semibold text-slate-900">{site.address.street}</p>
              <p class="text-sm text-slate-600">{site.address.city}, Colombia</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="h-11 w-11 rounded-xl bg-white grid place-items-center ring-1 ring-slate-200 text-brand-700">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Teléfonos</p>
              <p class="text-sm">
                <a href={`tel:+57${site.phone.landline}`} class="font-semibold text-slate-900 hover:text-brand-700">
                  {site.phone.landlineDisplay}
                </a>
                <span class="text-slate-400 mx-2">·</span>
                <a href={`tel:+57${site.phone.mobile}`} class="font-semibold text-slate-900 hover:text-brand-700">
                  {site.phone.mobileDisplay}
                </a>
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="h-11 w-11 rounded-xl bg-white grid place-items-center ring-1 ring-slate-200 text-brand-700">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Correo electrónico</p>
              <a href={`mailto:${site.email}`} class="text-sm font-semibold text-slate-900 hover:text-brand-700">
                {site.email}
              </a>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="h-11 w-11 rounded-xl bg-white grid place-items-center ring-1 ring-slate-200 text-brand-700">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Horario de atención</p>
              <p class="text-sm font-semibold text-slate-900">{site.hours.weekdays}</p>
              <p class="text-sm text-slate-600">{site.hours.saturday}</p>
            </div>
          </li>
        </ul>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={site.social.whatsapp}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-full bg-accent-500 hover:bg-accent-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-accent-500/30"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.34 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.515 5.26l-.999 3.648 3.973-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
            WhatsApp
          </a>
          <a
            href={`tel:+57${site.phone.mobile}`}
            class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-base font-semibold text-slate-800 ring-1 ring-slate-200 hover:ring-brand-300"
          >
            Llamar ahora
          </a>
        </div>
      </div>

      <div class="rounded-3xl overflow-hidden ring-1 ring-slate-200 shadow-xl shadow-brand-900/10 bg-white min-h-[420px]">
        <iframe
          src={mapsUrl}
          width="100%"
          height="100%"
          style="border:0; min-height: 420px;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación VIP CRC"
        ></iframe>
      </div>
    </div>
  </div>
</section>
