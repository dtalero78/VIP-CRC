---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid lg:grid-cols-4 gap-10">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3">
          <img
            src="/logo.png"
            alt="VIP Salud Ocupacional"
            width="40"
            height="40"
            class="h-10 w-10 object-contain bg-white rounded-xl p-1"
          />
          <div class="leading-tight">
            <span class="block text-sm font-bold text-white">{site.brand}</span>
            <span class="block text-[11px] text-slate-400">{site.legalName}</span>
          </div>
        </div>
        <p class="mt-5 text-sm text-slate-400 max-w-md leading-relaxed">
          Centro de Reconocimiento de Conductores en Bogotá, habilitado por el Ministerio de Transporte
          y certificado por la ONAC. Reporte automático al RUNT.
        </p>
        <p class="mt-4 text-xs text-slate-500">NIT {site.nit}</p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Navegación</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="#servicios" class="hover:text-white">Servicios</a></li>
          <li><a href="#categorias" class="hover:text-white">Categorías</a></li>
          <li><a href="#proceso" class="hover:text-white">Proceso</a></li>
          <li><a href="#precios" class="hover:text-white">Precios</a></li>
          <li><a href="#faq" class="hover:text-white">Preguntas frecuentes</a></li>
          <li><a href="#contacto" class="hover:text-white">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Contacto</h3>
        <ul class="mt-4 space-y-2 text-sm text-slate-400">
          <li>{site.address.street}</li>
          <li>{site.address.city}, Colombia</li>
          <li>
            <a href={`tel:+57${site.phone.landline}`} class="hover:text-white">{site.phone.landlineDisplay}</a>
          </li>
          <li>
            <a href={`tel:+57${site.phone.mobile}`} class="hover:text-white">{site.phone.mobileDisplay}</a>
          </li>
          <li><a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500">
        © {year} {site.legalName}. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-3 text-slate-400">
        <a href={site.social.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp" class="hover:text-white">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.34 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24z"/></svg>
        </a>
        <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="hover:text-white">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.45 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>
        </a>
        <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="hover:text-white">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<a
  href={site.social.whatsapp}
  target="_blank"
  rel="noopener"
  aria-label="Escríbenos por WhatsApp"
  class="fixed bottom-5 right-5 z-50 inline-flex items-center justify-center h-14 w-14 rounded-full bg-accent-500 hover:bg-accent-600 text-white shadow-2xl shadow-accent-500/40 animate-pulse-ring"
>
  <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.34 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.515 5.26l-.999 3.648 3.973-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
</a>
