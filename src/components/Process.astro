---
const steps = [
  {
    n: '01',
    title: 'Agenda tu cita',
    desc: 'Reserva por WhatsApp, llamada o el formulario de contacto. Atención inmediata o el mismo día.',
  },
  {
    n: '02',
    title: 'Realiza los exámenes',
    desc: 'En una sola visita completas los cuatro exámenes: medicina general, visual, auditivo y psicológico.',
  },
  {
    n: '03',
    title: 'Reporte al RUNT',
    desc: 'Tu certificado se sube de forma inmediata al sistema. Ya puedes tramitar tu licencia en cualquier sede.',
  },
];
---

<section id="proceso" class="py-20 lg:py-28 bg-white relative overflow-hidden">
  <div class="absolute -top-32 -right-32 h-96 w-96 rounded-full bg-brand-50 blur-3xl pointer-events-none"></div>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative">
    <div class="max-w-2xl">
      <span class="inline-flex items-center text-xs font-bold uppercase tracking-wider text-brand-700">Proceso</span>
      <h2 class="mt-2 text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
        Tan simple como contar hasta tres
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Diseñamos un proceso ágil para que obtengas tu certificado el mismo día sin filas ni complicaciones.
      </p>
    </div>

    <ol class="mt-14 grid lg:grid-cols-3 gap-6 relative">
      {steps.map((s, i) => (
        <li class="relative rounded-3xl bg-gradient-to-br from-brand-50 to-white p-8 ring-1 ring-slate-100">
          <div class="text-5xl font-black bg-gradient-to-br from-brand-600 to-accent-500 bg-clip-text text-transparent">
            {s.n}
          </div>
          <h3 class="mt-3 text-xl font-bold text-slate-900">{s.title}</h3>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed">{s.desc}</p>
          {i < steps.length - 1 && (
            <svg class="hidden lg:block absolute top-1/2 -right-3 h-6 w-6 text-brand-300 -translate-y-1/2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          )}
        </li>
      ))}
    </ol>
  </div>
</section>
