---
import { site } from '../data/site';
---

<section id="inicio" class="relative overflow-hidden bg-gradient-to-b from-brand-50/60 via-white to-white">
  <div class="absolute inset-0 bg-radial-soft pointer-events-none"></div>
  <div class="absolute inset-0 bg-grid opacity-40 pointer-events-none [mask-image:linear-gradient(180deg,white,transparent)]"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-16 pb-24 lg:pt-24 lg:pb-32">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="animate-fade-up">
        <div class="inline-flex items-center gap-2 rounded-full bg-brand-100 px-3 py-1 text-xs font-semibold text-brand-800 ring-1 ring-brand-200">
          <span class="h-2 w-2 rounded-full bg-accent-500 animate-pulse-ring"></span>
          CRC habilitado por el Ministerio de Transporte · Certificado ONAC
        </div>

        <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-[1.05]">
          Tu <span class="bg-gradient-to-r from-brand-600 to-accent-500 bg-clip-text text-transparent">examen médico</span> para licencia de conducción, en menos de una hora.
        </h1>

        <p class="mt-6 text-lg text-slate-600 max-w-xl">
          Reporte inmediato al RUNT, atención sin filas y certificación válida en todo el país.
          Centro de Reconocimiento de Conductores en el corazón de Bogotá.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href={site.social.whatsapp}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-full bg-accent-500 hover:bg-accent-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-accent-500/30 transition-all hover:scale-[1.02]"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.34 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.515 5.26l-.999 3.648 3.973-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
            Agendar por WhatsApp
          </a>
          <a
            href="#precios"
            class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-base font-semibold text-slate-800 ring-1 ring-slate-200 hover:ring-brand-300 hover:text-brand-700 transition-colors"
          >
            Ver precios
          </a>
        </div>

        <dl class="mt-10 grid grid-cols-3 gap-6 max-w-md">
          <div>
            <dt class="text-3xl font-bold text-brand-700">+10k</dt>
            <dd class="text-xs text-slate-500 mt-1">conductores certificados</dd>
          </div>
          <div>
            <dt class="text-3xl font-bold text-brand-700">45 min</dt>
            <dd class="text-xs text-slate-500 mt-1">tiempo promedio</dd>
          </div>
          <div>
            <dt class="text-3xl font-bold text-brand-700">100%</dt>
            <dd class="text-xs text-slate-500 mt-1">reporte al RUNT</dd>
          </div>
        </dl>
      </div>

      <div class="relative animate-fade-up [animation-delay:120ms]">
        <div class="relative aspect-[4/5] max-w-md mx-auto">
          <div class="absolute -top-6 -left-6 h-32 w-32 rounded-3xl bg-gradient-to-br from-brand-400 to-brand-700 animate-float-slow"></div>
          <div class="absolute -bottom-8 -right-4 h-40 w-40 rounded-full bg-gradient-to-br from-accent-400 to-accent-600 animate-float-slow [animation-delay:1.2s]"></div>

          <div class="relative h-full w-full rounded-3xl bg-white shadow-2xl shadow-brand-900/10 ring-1 ring-slate-100 overflow-hidden">
            <div class="p-6 border-b border-slate-100 flex items-center gap-3">
              <div class="h-10 w-10 rounded-xl bg-brand-100 grid place-items-center text-brand-700">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-900">Tu cita en 3 pasos</p>
                <p class="text-xs text-slate-500">Disponibilidad hoy mismo</p>
              </div>
            </div>
            <ul class="p-6 space-y-4 text-sm">
              <li class="flex gap-3">
                <span class="grid place-items-center h-7 w-7 rounded-full bg-brand-600 text-white text-xs font-bold flex-shrink-0">1</span>
                <div>
                  <p class="font-semibold text-slate-900">Agenda en línea</p>
                  <p class="text-slate-500 text-xs">Por WhatsApp o llamada en menos de 1 minuto.</p>
                </div>
              </li>
              <li class="flex gap-3">
                <span class="grid place-items-center h-7 w-7 rounded-full bg-brand-600 text-white text-xs font-bold flex-shrink-0">2</span>
                <div>
                  <p class="font-semibold text-slate-900">Realiza tus exámenes</p>
                  <p class="text-slate-500 text-xs">Visual, auditivo, psicológico y medicina general.</p>
                </div>
              </li>
              <li class="flex gap-3">
                <span class="grid place-items-center h-7 w-7 rounded-full bg-accent-500 text-white text-xs font-bold flex-shrink-0">3</span>
                <div>
                  <p class="font-semibold text-slate-900">Reporte al RUNT</p>
                  <p class="text-slate-500 text-xs">Recibe tu certificado y tramita tu licencia.</p>
                </div>
              </li>
            </ul>
            <div class="mx-6 mb-6 rounded-2xl bg-brand-50 p-4 ring-1 ring-brand-100">
              <p class="text-xs text-brand-800 font-semibold">Promoción online</p>
              <div class="flex items-baseline gap-2 mt-1">
                <span class="text-2xl font-extrabold text-brand-900">$180.000</span>
                <span class="text-xs text-slate-500 line-through">$250.000</span>
              </div>
              <p class="text-[11px] text-slate-500 mt-1">1 categoría · pago en línea</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
