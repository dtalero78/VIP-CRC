---
const categories = [
  {
    code: 'A',
    name: 'Motocicletas',
    description: 'Para motos y mototriciclos.',
    items: ['A1 — hasta 125 cc', 'A2 — más de 125 cc'],
    accent: 'from-brand-500 to-brand-700',
  },
  {
    code: 'B',
    name: 'Servicio particular',
    description: 'Vehículos para uso personal y familiar.',
    items: ['B1 — automóviles, camperos', 'B2 — camiones rígidos', 'B3 — vehículos articulados'],
    accent: 'from-accent-500 to-brand-600',
  },
  {
    code: 'C',
    name: 'Servicio público',
    description: 'Para conductores profesionales.',
    items: ['C1 — taxis, particulares', 'C2 — camiones de carga', 'C3 — articulados de carga'],
    accent: 'from-brand-700 to-brand-900',
  },
];
---

<section id="categorias" class="py-20 lg:py-28 bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <span class="inline-flex items-center text-xs font-bold uppercase tracking-wider text-brand-700">Categorías</span>
      <h2 class="mt-2 text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
        ¿Qué categoría de licencia necesitas?
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Atendemos todas las categorías de licencia de conducción en Colombia, tanto para primera vez,
        renovación, recategorización o refrendación.
      </p>
    </div>

    <div class="mt-12 grid lg:grid-cols-3 gap-6">
      {categories.map((c) => (
        <article class="relative rounded-3xl bg-white p-7 ring-1 ring-slate-100 hover:shadow-2xl hover:shadow-brand-900/10 hover:-translate-y-1 transition-all">
          <div class={`inline-flex items-center justify-center h-14 w-14 rounded-2xl bg-gradient-to-br ${c.accent} text-white text-xl font-extrabold shadow-lg`}>
            {c.code}
          </div>
          <h3 class="mt-5 text-xl font-bold text-slate-900">{c.name}</h3>
          <p class="mt-1 text-sm text-slate-600">{c.description}</p>
          <ul class="mt-5 space-y-2 text-sm text-slate-700">
            {c.items.map((it) => (
              <li class="flex items-start gap-2">
                <svg class="h-5 w-5 text-accent-600 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span>{it}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
      {['Primera vez', 'Renovación', 'Recategorización', 'Refrendación'].map((label) => (
        <div class="rounded-2xl bg-white p-4 ring-1 ring-slate-100 flex items-center gap-3">
          <div class="h-9 w-9 rounded-lg bg-brand-50 grid place-items-center text-brand-700">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
          </div>
          <p class="text-sm font-semibold text-slate-800">{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
